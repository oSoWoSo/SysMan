# Subpackage: sysman-common (Common files - lang, icons)
sysman-common_package() {
	short_desc="SysMan common files (required by all modules)"
	depends="libglvnd"
	pkg_install() {
		vmkdir usr/share/SysMan/lang
		vcopy build/lang/* usr/share/SysMan/lang/
		vmkdir usr/share/pixmaps
		vcopy src/common/void-transparent.png usr/share/pixmaps/
	}
}
