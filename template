# Template file for 'sysman'
pkgname=sysman
version=0.014
revision=1
archs="x86_64*"
hostmakedepends="go pkg-config"
makedepends="libX11-devel libXrandr-devel libXxf86vm-devel libXi-devel
 libXcursor-devel libXinerama-devel glu-devel"
short_desc="Full system manager - services, packages, templates, users, VMs"
maintainer="zenobit <zenobit@disroot.org>"
license="MIT"
homepage="https://codeberg.org/oSoWoSo/SysMan"
changelog="https://codeberg.org/oSoWoSo/SysMan/raw/branch/main/CHANGELOG.md"
distfiles="https://codeberg.org/oSoWoSo/SysMan/archive/v${version}.tar.gz#template"
checksum=skip
build_style=gnu-makefile
make_build_args="build build-tui"
export PREFIX=/usr

do_build() {
	make build
	make build-tui
}

do_check() {
	make test
}

do_install() {
	make install

	# Main sysman binary
	vbin build/sysman

	# Common files - shared between all modules
	vmkdir usr/share/SysMan/lang
	vcopy build/lang/* usr/share/SysMan/lang/
	vmkdir usr/share/pixmaps
	vcopy src/common/void-transparent.png usr/share/pixmaps
}

# Subpackage: sysman-serman (Services manager - runit)
sysman-serman_package() {
	short_desc="Services manager (runit)"
	depends="sysman-common-${version}_${revision}"
	pkg_install() {
		vbin build/serman
		vbin build/serman-tui
		vcopy build/lang/serman usr/share/SysMan/lang/
	}
}

# Subpackage: sysman-pkgman (Packages manager - xbps)
sysman-pkgman_package() {
	short_desc="Packages manager (xbps)"
	depends="sysman-common-${version}_${revision} xbps"
	pkg_install() {
		vbin build/pkgman
		vbin build/pkgman-tui
		vcopy build/lang/pkgman usr/share/SysMan/lang/
	}
}

